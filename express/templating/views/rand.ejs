<!DOCTYPE html>
<html lang="en">
<%- include("partials/head") %>
<body>
    <%- include("partials/navbar") %>
    <h1>This is your random  number: <%= rand %></h1>
    <% if (rand % 2 === 0){ %>
    <h2>Even</h2>
    <% } else { %>
    <h2>Odd</h2>
    <% } %>

    <h3><%= rand % 2 === 0 ? "Even" : "Odd" %></h3>
</body>
</html>

